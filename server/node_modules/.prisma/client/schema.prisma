datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 1. USER & CO-OP COMPANY PROFILE
// ==========================================
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyMemberships CompanyMember[]

  @@index([username])
}

model Clan {
  id         String   @id @default(cuid())
  name       String   @unique
  treasury   Decimal  @default(0.00) @db.Decimal(18, 2)
  reputation Int      @default(0)
  createdAt  DateTime @default(now())

  companies Company[]
}

model Company {
  id                 String   @id @default(cuid())
  name               String   @unique
  legalBalance       Decimal  @default(50000.00) @db.Decimal(18, 2)
  blackMarketBalance Decimal  @default(0.00) @db.Decimal(18, 2)
  reputationScore    Int      @default(0) // Underworld rep
  policeHeat         Int      @default(0) // Heat scale (0-100)
  clanId             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  clan         Clan?           @relation(fields: [clanId], references: [id], onDelete: SetNull)
  members      CompanyMember[]
  garages      Garage[]
  trucks       Truck[]
  drivers      Driver[]
  activeRoutes ActiveRoute[]
  fronts       FrontBusiness[]

  // Auctions (Companies bid and sell, not individual users)
  listings    AuctionListing[] @relation("SellerAuctions")
  highestBids AuctionListing[] @relation("HighestBidderAuctions")
  bidLogs     AuctionBidLog[]

  @@index([clanId])
}

model CompanyMember {
  id        String      @id @default(cuid())
  userId    String
  companyId String
  role      CompanyRole @default(EMPLOYEE)
  joinedAt  DateTime    @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
}

// ==========================================
// 2. FLEET & INFRASTRUCTURE
// ==========================================
model Garage {
  id           String  @id @default(cuid())
  companyId    String
  city         String // e.g., "Riga", "Tallinn", "Warsaw"
  capacity     Int     @default(3)
  upgradeLevel Int     @default(1)
  hasStashRoom Boolean @default(false) // Hides minor stash from local raids

  // Storage for global commodities
  dieselStorage      Float @default(0.0) // Liters
  maxDiesel          Float @default(5000.0)
  electricityStorage Float @default(0.0) // kWh
  maxElectricity     Float @default(1000.0)
  adblueStorage      Float @default(0.0) // Liters
  maxAdblue          Float @default(500.0)
  co2Allowances      Float @default(0.0) // Tons

  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  trucks  Truck[]

  @@index([companyId])
}

model Truck {
  id               String      @id @default(cuid())
  companyId        String
  garageId         String
  model            String // e.g., "Scania R500", "Volvo FH16"
  vin              String      @unique
  mileage          Float       @default(0.0)
  engineHealth     Int         @default(100) // Percent (0-100)
  tireWear         Int         @default(100) // Percent (0-100)
  fuelCapacity     Float       @default(400.0) // Liters
  fuelTankMod      FuelTankMod @default(STOCK)
  scannerShielding Int         @default(0) // Level of lead shielding (0-5)
  isImpounded      Boolean     @default(false)
  impoundReleaseAt DateTime?
  createdAt        DateTime    @default(now())

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  garage          Garage           @relation(fields: [garageId], references: [id], onDelete: Restrict)
  driver          Driver?          @relation("TruckDriver")
  history         TruckHistory[]
  activeRoute     ActiveRoute?
  auctionListings AuctionListing[]

  @@index([companyId])
  @@index([garageId])
}

model TruckHistory {
  id          String   @id @default(cuid())
  truckId     String
  eventType   String // e.g., "PURCHASE", "REPAIR", "BORDER_BUST", "MODIFICATION", "AUCTION_SALE"
  description String
  recordedAt  DateTime @default(now())

  truck Truck @relation(fields: [truckId], references: [id], onDelete: Cascade)

  @@index([truckId])
}

// ==========================================
// 3. HUMAN RESOURCES (DRIVERS)
// ==========================================
model Driver {
  id              String      @id @default(cuid())
  companyId       String
  name            String
  trait           DriverTrait @default(BALANCED)
  charisma        Int         @default(10) // 1 to 20 (effects bribe success)
  loyalty         Int         @default(50) // 0 to 100 (affects running the border vs snitching)
  fatigue         Int         @default(0) // 0 to 100 (high fatigue causes wrecks)
  tachoHours      Float       @default(0.0) // Schengen tachometer log: 0.0 to 10.0 hours
  isStimulated    Boolean     @default(false) // Substance usage fatigue override active
  assignedTruckId String?     @unique
  createdAt       DateTime    @default(now())

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedTruck Truck?        @relation("TruckDriver", fields: [assignedTruckId], references: [id], onDelete: SetNull)
  activeRoutes  ActiveRoute[]

  @@index([companyId])
}

// ==========================================
// 4. THE CONTRACTS & SMUGGLING WORKFLOW
// ==========================================
model LegalContract {
  id            String        @id @default(cuid())
  cargoType     CargoType
  origin        String
  destination   String
  deadlineHours Int           @default(24)
  payoutLegal   Decimal       @db.Decimal(18, 2)
  distanceKm    Float
  createdAt     DateTime      @default(now())
  activeRoutes  ActiveRoute[]
}

model ContrabandJob {
  id             String          @id @default(cuid())
  cargoClass     ContrabandClass
  riskMultiplier Float // Scale 1.0 to 5.0
  payoutBlack    Decimal         @db.Decimal(18, 2)
  payoutLegal    Decimal         @default(0.00) @db.Decimal(18, 2) // laundered payout if any
  origin         String
  destination    String
  createdAt      DateTime        @default(now())
  activeRoutes   ActiveRoute[]
}

model ActiveRoute {
  id                 String   @id @default(cuid())
  companyId          String
  truckId            String   @unique
  driverId           String
  legalContractId    String?
  contrabandJobId    String?
  progressPct        Float    @default(0.0) // 0.0 to 100.0
  departedAt         DateTime @default(now())
  eta                DateTime
  currentCity        String
  isUnderBorderCheck Boolean  @default(false)

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  truck         Truck          @relation(fields: [truckId], references: [id], onDelete: Restrict)
  driver        Driver         @relation(fields: [driverId], references: [id], onDelete: Restrict)
  legalContract LegalContract? @relation(fields: [legalContractId], references: [id], onDelete: SetNull)
  contrabandJob ContrabandJob? @relation(fields: [contrabandJobId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([truckId])
}

// ==========================================
// 5. THE BIDDING ECONOMY (AUCTION HOUSE)
// ==========================================
model AuctionListing {
  id                     String        @id @default(cuid())
  truckId                String
  sellerCompanyId        String
  startingPrice          Decimal       @db.Decimal(18, 2)
  currentBid             Decimal       @db.Decimal(18, 2)
  highestBidderCompanyId String?
  reservePrice           Decimal?      @db.Decimal(18, 2)
  expiresAt              DateTime
  status                 AuctionStatus @default(ACTIVE)
  createdAt              DateTime      @default(now())
  settledAt              DateTime?

  truck                Truck           @relation(fields: [truckId], references: [id], onDelete: Restrict)
  sellerCompany        Company         @relation("SellerAuctions", fields: [sellerCompanyId], references: [id], onDelete: Cascade)
  highestBidderCompany Company?        @relation("HighestBidderAuctions", fields: [highestBidderCompanyId], references: [id], onDelete: SetNull)
  bidLogs              AuctionBidLog[]

  @@index([truckId])
  @@index([sellerCompanyId])
  @@index([highestBidderCompanyId])
  @@index([status])
}

model AuctionBidLog {
  id              String   @id @default(cuid())
  auctionId       String
  bidderCompanyId String
  amount          Decimal  @db.Decimal(18, 2)
  bidAt           DateTime @default(now())

  auction       AuctionListing @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidderCompany Company        @relation(fields: [bidderCompanyId], references: [id], onDelete: Cascade)

  @@index([auctionId])
  @@index([bidderCompanyId])
}

// ==========================================
// 6. GLOBAL COMMODITY MARKET
// ==========================================
model CommodityMarket {
  id              String        @id @default(cuid())
  commodityType   CommodityType @unique
  currentPrice    Decimal       @db.Decimal(18, 2) // Cost per unit
  lastUpdated     DateTime      @default(now())
  volatilityIndex Float         @default(1.0)
}

// ==========================================
// 7. ENUMS
// ==========================================
enum CompanyRole {
  OWNER
  PARTNER
  EMPLOYEE
}

enum CommodityType {
  DIESEL
  ELECTRICITY
  ADBLUE
  CO2_ALLOWANCE
}

enum FuelTankMod {
  STOCK
  FALSE_BOTTOM // Hides 50L capacity, holds Class A or B
  CHASSIS_CAVITY // Double stash size, hurts truck handling (-20% handling, -10% fuel eco)
}

enum ContrabandClass {
  CLASS_A // Luxuries / Tax-evaded goods (Low Risk, High Volume)
  CLASS_B // Restricted narcotics/chemicals (Medium Risk, High Payout)
  CLASS_C // High-grade weapons / Radioactive materials (Extreme Risk, Astronomical Payout)
}

enum DriverTrait {
  BALANCED
  LEAD_FOOT // 15% speed increase, +10% wear & tear, +10% fuel use
  SLEEP_DEPRIVED // Fatigue rises faster, but accepts 12h shifts
  LOYAL // Low bribe failure, never snitches on contraband busts
  CHARISMATIC // +30% bribe success rate
}

enum CargoType {
  ELECTRONICS
  AGRICULTURAL_MACHINERY
  DAIRY_PRODUCTS
  TIMBER
  PHARMACEUTICALS
  STEEL_COILS
}

enum AuctionStatus {
  ACTIVE
  CLOSED_UNSOLD
  CLOSED_SOLD
}

// ==========================================
// 8. MONEY LAUNDERING FRONTS
// ==========================================
model FrontBusiness {
  id             String    @id @default(cuid())
  companyId      String
  name           String // e.g., "Kaunas Taxi Co", "Bialystok cafe"
  city           String
  laundryRate    Decimal   @default(500.00) @db.Decimal(18, 2) // Max dirty cash laundered per check cycle
  lossMultiplier Float     @default(0.80) // 80% returned as clean cash (20% laundering fee)
  upgradeLevel   Int       @default(1)
  isRaided       Boolean   @default(false)
  raidCooldown   DateTime?
  createdAt      DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}
