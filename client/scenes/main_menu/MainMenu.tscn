theme_override_font_sizes/font_size = 13
text = "Real-time global used-truck auction blocks are persistent. Flip, bid, and trade rigs with other players. Leverage the \"Buyer Beware\" economy: cover structural damages, hide smuggling hot histories, and clear the listing. Buyers only receive complete mechanical VIN reports after the auction block closes."
