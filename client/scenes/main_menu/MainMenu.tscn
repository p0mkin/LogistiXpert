[node name="DescSmuggle" type="Label" parent="Margin/HBox/RightPanel/TerminalPanel/Margin/InfoBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.709804, 0.768627, 0.843137, 1)
theme_override_font_sizes/font_size = 13
text = "Back-alley dealers will offer high-yield Class A/B/C contraband contracts crossing non-Schengen custom borders (Minsk, Brest). Ensure vehicles have falso-bottom fuel tanks or scanner lead-shielding to bypass custom X-Ray and K9 patrols, or be prepared to bribe guards or run checkpoints."
